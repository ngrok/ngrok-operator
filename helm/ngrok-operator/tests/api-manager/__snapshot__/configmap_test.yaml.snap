should match snapshot:
  1: |
    apiVersion: v1
    data:
      clusterDomain: svc.cluster.local
      description: The official ngrok Kubernetes Operator.
      features.bindings.enabled: "false"
      features.defaultDomainReclaimPolicy: Delete
      features.drainPolicy: Retain
      features.gateway.disableReferenceGrants: "false"
      features.gateway.enabled: "true"
      features.ingress.controllerName: k8s.ngrok.com/ingress-controller
      features.ingress.enabled: "true"
      log.format: json
      log.level: info
      log.stacktraceLevel: error
      oneClickDemoMode: "false"
    kind: ConfigMap
    metadata:
      labels:
        app.kubernetes.io/component: controller
        app.kubernetes.io/instance: test-release
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: ngrok-operator
        app.kubernetes.io/part-of: ngrok-operator
        app.kubernetes.io/version: 0.21.0
        helm.sh/chart: ngrok-operator-0.23.0
      name: test-release-ngrok-operator-api-manager-config
      namespace: test-namespace
